# Exemplo de configuração de ambiente do promptdown-frontend.
# Copie para `.env` (ignorado pelo Git) e ajuste os valores.
#
# API_BASE_URL é o ÚNICO ponto de acoplamento do frontend com o backend.
# Todo consumo da API DEVE ser feito exclusivamente através desta variável
# (ver src/js/config/constants.js). Sem barra final.
#
# Observação: em JS Vanilla puro esta variável não chega sozinha ao browser;
# ela é lida pelo processo que serve/builda a aplicação e exposta ao cliente
# (ex.: injeção em constants.js). Nunca coloque segredos aqui — apenas a URL base.
API_BASE_URL=http://localhost:3000
